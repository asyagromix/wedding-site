{
  "rewrites": [
    {
      "source": "/submit_form",
      "destination": "/api/submit_form"
    },
    {
      "source": "/link_vk.php",
      "destination": "/api/link_vk.php"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/_next/:match*",
      "destination": "https://eventrix.pro/_next/:match*"
    },
    {
      "source": "/templates/:match*",
      "destination": "https://eventrix.pro/templates/:match*"
    },
    {
      "source": "/((?!_next/|templates/|usersFiles/|favicon\\.ico|.*\\.jpg|.*\\.png).*)",
      "destination": "/index.html"
    }
  ]
}
